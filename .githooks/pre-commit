#!/usr/bin/env bash
set -euo pipefail

cargo fmt --all

mapfile -t fmt_changed < <(git diff --name-only --diff-filter=M -- '*.rs')
if [ ${#fmt_changed[@]} -gt 0 ]; then
    git add "${fmt_changed[@]}"
fi

cargo clippy --workspace --all-targets -- \
  -D warnings \
  -A clippy::manual_is_multiple_of \
  -A clippy::too_many_arguments
